# Template for restic repository configuration
# Copy this to /etc/restic/<name>.repo.env and fill in the values

# The location of the restic repository
RESTIC_REPOSITORY="/mnt/backups/change-me"

# The file containing the repository password
RESTIC_PASSWORD_FILE="/etc/restic/change-me.repo.key"

# Additional environment variables can be added here
# e.g., for S3:
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
