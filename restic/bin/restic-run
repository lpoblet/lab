#!/bin/bash
# restic-run: A wrapper script to run restic commands using a specific repository config.
# Usage: restic-run <config-name> <restic-command> [args...]
# Example: ./restic-run home snapshots

CONFIG_NAME=$1
shift

if [ -z "$CONFIG_NAME" ]; then
    echo "Usage: $0 <config-name> <restic-command> [args...]"
    exit 1
fi

ENV_FILE="/etc/restic/${CONFIG_NAME}.repo.env"

if [ ! -f "$ENV_FILE" ]; then
    echo "Error: Configuration file $ENV_FILE not found."
    exit 1
fi

# Load environment variables
source "$ENV_FILE"

# Run restic
restic "$@"
